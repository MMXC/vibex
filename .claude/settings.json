{
    "attribution": {
        "co_authored_by": true,
        "co_author_name": "Claude Opus 4.6",
        "co_author_email": "noreply@anthropic.com"
    },
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "cd \"$(./scripts/hooks/find-project-root.sh)\" && python3 scripts/hooks/loop-detection.py",
                        "timeout": 5
                    },
                    {
                        "type": "command",
                        "command": "cd \"$(./scripts/hooks/find-project-root.sh)\" && python3 scripts/hooks/risk-tracker.py 2>/dev/null || true",
                        "timeout": 3
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "cd \"$(./scripts/hooks/find-project-root.sh)\" && python3 scripts/deploy-guard.py",
                        "timeout": 10
                    },
                    {
                        "type": "command",
                        "command": "cd \"$(./scripts/hooks/find-project-root.sh)\" && python3 scripts/hooks/auto-python3.py",
                        "timeout": 5
                    }
                ]
            },
            {
                "matcher": "Task",
                "hooks": [
                    {
                        "type": "command",
                        "command": "cd \"$(./scripts/hooks/find-project-root.sh)\" && python3 scripts/hooks/review-agent-gatekeeper.py",
                        "timeout": 5
                    }
                ]
            },
            {
                "matcher": "Read|Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "cd \"$(./scripts/hooks/find-project-root.sh)\" && python3 scripts/hooks/sanitize-on-read.py",
                        "timeout": 10
                    }
                ]
            },
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "cd \"$(./scripts/hooks/find-project-root.sh)\" && python3 scripts/hooks/tool-call-counter.py 2>/dev/null || true",
                        "timeout": 5
                    }
                ]
            }
        ],
        "Stop": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "cd \"$(./scripts/hooks/find-project-root.sh)\" && python3 scripts/hooks/stop-evaluator.py",
                        "timeout": 15
                    }
                ]
            }
        ],
        "SessionStart": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "cd \"$(./scripts/hooks/find-project-root.sh)\" && python3 scripts/hooks/session-start-reset-risk.py 2>/dev/null || true",
                        "timeout": 5
                    },
                    {
                        "type": "command",
                        "command": "cd \"$(./scripts/hooks/find-project-root.sh)\" && python3 scripts/hooks/session-start-magic-docs.py 2>/dev/null || true",
                        "timeout": 5
                    },
                    {
                        "type": "command",
                        "command": "cd \"$(./scripts/hooks/find-project-root.sh)\" && python3 scripts/hooks/session-start-toolkit-reminder.py 2>/dev/null || true",
                        "timeout": 5
                    }
                ]
            }
        ],
        "SessionEnd": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "cd \"$(./scripts/hooks/find-project-root.sh)\" && python3 scripts/hooks/session-reflection.py 2>/dev/null || true",
                        "timeout": 10
                    }
                ]
            }
        ]
    }
}
