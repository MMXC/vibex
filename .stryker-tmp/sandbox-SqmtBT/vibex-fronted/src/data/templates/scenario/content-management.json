{
  "id": "scenario-content-management",
  "name": "内容管理",
  "displayName": "通用内容管理模块",
  "category": "scenario",
  "icon": "📄",
  "description": "通用的内容发布和管理模块，支持多种内容类型",
  "content": "开发一个通用内容管理模块，包含以下核心功能：\n\n1. 内容类型：支持文章、动态、问答等多种内容类型\n2. 内容创建：富文本编辑、Markdown支持、图片/视频上传\n3. 内容管理：发布、编辑、删除、回收站\n4. 分类管理：多级分类、标签管理\n5. 内容审核：待审列表、敏感词过滤、审核通过/拒绝\n6. 评论管理：发表评论、回复、审核、删除\n7. 内容搜索：关键词搜索、分类筛选、排序",
  "entities": [
    {
      "name": "Content",
      "type": "aggregate",
      "attributes": ["id", "type", "authorId", "title", "body", "coverImage", "categoryId", "tags", "status", "viewCount", "likeCount", "commentCount", "publishedAt", "createdAt", "updatedAt"],
      "description": "内容聚合根"
    },
    {
      "name": "Category",
      "type": "entity",
      "attributes": ["id", "name", "slug", "parentId", "sortOrder", "icon"],
      "description": "分类"
    },
    {
      "name": "Tag",
      "type": "entity",
      "attributes": ["id", "name", "slug", "usageCount"],
      "description": "标签"
    },
    {
      "name": "Media",
      "type": "entity",
      "attributes": ["id", "url", "type", "filename", "size", "uploaderId", "createdAt"],
      "description": "媒体文件"
    },
    {
      "name": "Comment",
      "type": "entity",
      "attributes": ["id", "contentId", "userId", "body", "parentId", "likeCount", "status", "createdAt"],
      "description": "评论"
    },
    {
      "name": "Audit",
      "type": "entity",
      "attributes": ["id", "contentId", "auditorId", "action", "reason", "createdAt"],
      "description": "审核记录"
    }
  ],
  "features": [
    {
      "name": "内容创建",
      "priority": "core",
      "description": "富文本/Markdown编辑、图片视频上传、封面设置",
      "entities": ["Content", "Media"]
    },
    {
      "name": "内容管理",
      "priority": "core",
      "description": "发布、编辑、删除、回收站、批量操作",
      "entities": ["Content"]
    },
    {
      "name": "分类标签",
      "priority": "core",
      "description": "多级分类管理、标签管理、SEO设置",
      "entities": ["Category", "Tag"]
    },
    {
      "name": "内容审核",
      "priority": "important",
      "description": "待审列表、敏感词过滤、审核通过/拒绝",
      "entities": ["Content", "Audit"]
    },
    {
      "name": "评论系统",
      "priority": "important",
      "description": "发表评论、回复、评论审核、点赞",
      "entities": ["Comment", "Content"]
    },
    {
      "name": "内容搜索",
      "priority": "important",
      "description": "关键词搜索、分类筛选、热门排序",
      "entities": ["Content", "Category", "Tag"]
    }
  ],
  "metadata": {
    "complexity": "medium",
    "estimatedTime": "1-2周",
    "techStack": ["React", "Node.js", "MongoDB", "OSS"],
    "tags": ["内容管理", "CMS", "文章", "富文本", "评论"]
  }
}
