## Epic 2: 虚假完成检测（P0）

### Story 2.1-2.3: 虚假完成检测逻辑

**文件**: `current_report/_false_completion.py`

```python
import json
import os
from pathlib import Path

def detect_false_completions(tasks_path: str = None, workspace: str = None) -> dict:
    if tasks_path is None:
        tasks_path = "/root/.openclaw/workspace-coord/team-tasks/tasks.json"
    if workspace is None:
        workspace = "/root/.openclaw/vibex"
    
    with open(tasks_path) as f:
        data = json.load(f)
    
    items = []
    for project in data.get("projects", []):
        project_name = project.get("project", "")
        for task_name, task_info in project.get("stages", {}).items():
            if task_info.get("status") != "done":
                continue
            output = task_info.get("output", "")
            if not output:  # output 为空不检测
                continue
            # output 可以是相对路径或绝对路径
            if not output.startswith("/"):
                output = os.path.join(workspace, output)
            if not os.path.exists(output):
                items.append({
                    "project": project_name,
                    "task": task_name,
                    "missing_file": output
                })
    
    return {"count": len(items), "items": items}
```

