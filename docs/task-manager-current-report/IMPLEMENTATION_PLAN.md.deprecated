## Epic 1: 活跃项目状态（P0）

### Story 1.1: 读取 tasks.json 获取 active 项目列表

**文件**: `current_report/_active_projects.py`

```python
import json
from pathlib import Path

def get_active_projects(tasks_path: str = None) -> dict:
    if tasks_path is None:
        tasks_path = "/root/.openclaw/workspace-coord/team-tasks/tasks.json"
    
    with open(tasks_path) as f:
        data = json.load(f)
    
    active_projects = [
        p for p in data.get("projects", [])
        if p.get("status") == "active"
    ]
    
    return {
        "count": len(active_projects),
        "projects": [
            {
                "name": p["project"],
                "stage": _get_current_stage(p),
                "pending": _count_pending(p)
            }
            for p in active_projects
        ]
    }

def _get_current_stage(project: dict) -> str:
    """获取当前进行中的阶段名称"""
    stages = project.get("stages", {})
    for name, info in stages.items():
        if info.get("status") == "in-progress":
            return name
    # 没有 in-progress，返回最后一个非 done 的
    for name, info in reversed(list(stages.items())):
        if info.get("status") != "done":
            return name
    return "completed"

def _count_pending(project: dict) -> int:
    """统计 pending 任务数"""
    return sum(1 for info in project.get("stages", {}).values()
               if info.get("status") == "pending")
```

### Story 1.2: 格式化输出活跃项目

**文件**: `current_report/_output.py`

```python
def format_active_text(data: dict) -> str:
    lines = [f"=== Active Projects ({data['count']}) ==="]
    if not data["projects"]:
        lines.append("(none)")
    for p in data["projects"]:
        lines.append(f"- {p['name']}: stage={p['stage']}, pending={p['pending']}")
    return "\n".join(lines)
```

