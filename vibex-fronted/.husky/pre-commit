#!/bin/sh

# Vibex pre-commit hook
# E6: console.* pre-commit hook — ESLint no-console blocking

# Check for --no-verify skip option
if [ "$1" = "--no-verify" ]; then
  echo "Skipping pre-commit checks (--no-verify flag detected)"
  echo "WARNING: You are bypassing security checks!"
  exit 0
fi

# E6: Run lint-staged on staged files
# Blocks console.log/warn/error commits via @typescript-eslint/no-console rule
echo "Running lint-staged (E6: ESLint no-console check)..."
npx lint-staged
if [ $? -ne 0 ]; then
  echo "FAILED: lint-staged — fix ESLint errors before committing."
  echo "   console.log/warn/error blocked by @typescript-eslint/no-console rule."
  exit 1
fi

echo "Running pre-commit checks..."

# 1. gitleaks (sensitive data detection)
if command -v gitleaks &> /dev/null; then
  echo "Checking for sensitive data..."
  gitleaks detect --staged --config .gitleaks.toml --no-git
  if [ $? -ne 0 ]; then
    echo "FAILED: gitleaks detected sensitive data"
    exit 1
  fi
else
  echo "gitleaks not installed, skipping"
fi

# 2. npm audit
if [ -f "package.json" ]; then
  echo "Running npm audit..."
  npm audit --audit-level=high 2>/dev/null || echo "npm audit had warnings"
fi

# 3. TypeScript check (frontend)
if [ -f "tsconfig.json" ]; then
  echo "Running TypeScript check..."
  npx tsc --noEmit 2>&1 | grep -q "error TS"
  if [ $? -eq 0 ]; then
    echo "FAILED: TypeScript has errors"
    npx tsc --noEmit 2>&1 | head -5
    exit 1
  fi
fi

echo "All pre-commit checks passed!"
exit 0
