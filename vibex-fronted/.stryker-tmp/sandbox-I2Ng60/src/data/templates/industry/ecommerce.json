{
  "id": "ecommerce-b2c",
  "name": "B2C商城",
  "displayName": "B2C 电商商城",
  "category": "ecommerce",
  "icon": "🛒",
  "description": "包含商品管理、购物车、订单、支付、物流等核心电商功能",
  "content": "开发一个B2C电商商城，包含以下核心功能：\n\n1. 用户系统：注册登录、个人中心、收货地址管理\n2. 商品系统：商品列表、分类、搜索、详情页\n3. 购物车：添加商品、修改数量、结算\n4. 订单系统：下单、支付、订单跟踪\n5. 物流系统：快递查询、物流跟踪\n6. 后台管理：商品管理、订单管理、用户管理、数据统计",
  "entities": [
    {
      "name": "User",
      "type": "aggregate",
      "attributes": ["id", "email", "password", "name", "phone", "avatar", "addresses", "createdAt"],
      "description": "用户聚合根"
    },
    {
      "name": "Product",
      "type": "aggregate",
      "attributes": ["id", "name", "description", "price", "originalPrice", "stock", "categoryId", "images", "status"],
      "description": "商品聚合根"
    },
    {
      "name": "Category",
      "type": "entity",
      "attributes": ["id", "name", "parentId", "sortOrder"],
      "description": "商品分类"
    },
    {
      "name": "Cart",
      "type": "aggregate",
      "attributes": ["id", "userId", "items", "totalAmount"],
      "description": "购物车聚合根"
    },
    {
      "name": "CartItem",
      "type": "entity",
      "attributes": ["id", "cartId", "productId", "quantity", "price"],
      "description": "购物车项"
    },
    {
      "name": "Order",
      "type": "aggregate",
      "attributes": ["id", "orderNo", "userId", "items", "totalAmount", "status", "paymentId", "shippingAddress", "createdAt"],
      "description": "订单聚合根"
    },
    {
      "name": "Payment",
      "type": "entity",
      "attributes": ["id", "orderId", "amount", "method", "status", "transactionId"],
      "description": "支付记录"
    },
    {
      "name": "Shipping",
      "type": "entity",
      "attributes": ["id", "orderId", "carrier", "trackingNo", "status", "events"],
      "description": "物流信息"
    },
    {
      "name": "Address",
      "type": "valueObject",
      "attributes": ["receiver", "phone", "province", "city", "district", "detail", "isDefault"],
      "description": "收货地址"
    }
  ],
  "features": [
    {
      "name": "用户注册登录",
      "priority": "core",
      "description": "用户可以注册账号、登录系统、找回密码",
      "entities": ["User"]
    },
    {
      "name": "商品浏览",
      "priority": "core",
      "description": "用户可以浏览商品列表、分类筛选、关键词搜索、查看商品详情",
      "entities": ["Product", "Category"]
    },
    {
      "name": "购物车",
      "priority": "core",
      "description": "用户可以添加商品到购物车、修改数量、删除商品、计算总价",
      "entities": ["Cart", "CartItem", "Product"]
    },
    {
      "name": "下单支付",
      "priority": "core",
      "description": "用户可以选择收货地址、下单、选择支付方式、完成支付",
      "entities": ["Order", "Payment", "Address", "User"]
    },
    {
      "name": "订单管理",
      "priority": "core",
      "description": "用户可以查看订单列表、订单详情、物流跟踪、取消订单",
      "entities": ["Order", "Shipping"]
    },
    {
      "name": "个人中心",
      "priority": "important",
      "description": "用户可以管理收货地址、查看历史订单、修改个人资料",
      "entities": ["User", "Address", "Order"]
    },
    {
      "name": "后台商品管理",
      "priority": "core",
      "description": "管理员可以添加、编辑、删除商品，管理商品分类",
      "entities": ["Product", "Category"]
    },
    {
      "name": "后台订单管理",
      "priority": "core",
      "description": "管理员可以查看订单、修改订单状态、处理退款",
      "entities": ["Order", "Payment"]
    }
  ],
  "metadata": {
    "complexity": "medium",
    "estimatedTime": "2-3周",
    "techStack": ["React", "Node.js", "PostgreSQL", "Redis"],
    "tags": ["电商", "商城", "B2C", "购物", "订单", "支付", "物流"]
  }
}
