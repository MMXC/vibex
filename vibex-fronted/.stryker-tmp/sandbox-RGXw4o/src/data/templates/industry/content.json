{
  "id": "content-cms",
  "name": "内容管理",
  "displayName": "内容管理系统 CMS",
  "category": "content",
  "icon": "📝",
  "description": "文章管理、分类标签、媒体库、内容审核等CMS功能",
  "content": "开发一个内容管理系统 CMS，包含以下核心功能：\n\n1. 文章管理：文章创建、编辑、发布、定时发布、版本管理\n2. 分类标签：栏目管理、标签管理、SEO配置\n3. 媒体库：图片/视频上传、管理、CDN加速\n4. 内容审核：待审列表、敏感词过滤、批量审核\n5. 评论管理：评论审核、敏感评论过滤、垃圾评论识别\n6. 用户系统：作者管理、角色权限、工作流\n7. 数据统计：访问统计、热门文章、用户行为分析",
  "entities": [
    {
      "name": "User",
      "type": "aggregate",
      "attributes": ["id", "username", "email", "password", "name", "avatar", "role", "status", "createdAt"],
      "description": "用户聚合根（编辑/作者/管理员）"
    },
    {
      "name": "Article",
      "type": "aggregate",
      "attributes": ["id", "authorId", "title", "slug", "content", "excerpt", "coverImage", "categoryId", "tags", "status", "publishedAt", "viewCount", "likeCount", "commentCount", "createdAt", "updatedAt"],
      "description": "文章聚合根"
    },
    {
      "name": "Category",
      "type": "entity",
      "attributes": ["id", "name", "slug", "description", "parentId", "sortOrder", "seoTitle", "seoDescription"],
      "description": "栏目分类"
    },
    {
      "name": "Tag",
      "type": "entity",
      "attributes": ["id", "name", "slug", "articleCount"],
      "description": "标签"
    },
    {
      "name": "Media",
      "type": "entity",
      "attributes": ["id", "filename", "url", "type", "size", "width", "height", "uploaderId", "createdAt"],
      "description": "媒体文件"
    },
    {
      "name": "Comment",
      "type": "entity",
      "attributes": ["id", "articleId", "userId", "content", "parentId", "status", "ip", "userAgent", "createdAt"],
      "description": "评论"
    },
    {
      "name": "Revision",
      "type": "entity",
      "attributes": ["id", "articleId", "authorId", "content", "createdAt"],
      "description": "文章版本"
    },
    {
      "name": "AuditLog",
      "type": "entity",
      "attributes": ["id", "userId", "action", "targetType", "targetId", "details", "createdAt"],
      "description": "审核日志"
    },
    {
      "name": "Page",
      "type": "entity",
      "attributes": ["id", "title", "slug", "content", "template", "status", "createdAt"],
      "description": "单页"
    },
    {
      "name": "Link",
      "type": "entity",
      "attributes": ["id", "name", "url", "logo", "description", "sortOrder", "status"],
      "description": "友情链接"
    }
  ],
  "features": [
    {
      "name": "用户权限",
      "priority": "core",
      "description": "用户管理、角色权限、工作流配置",
      "entities": ["User"]
    },
    {
      "name": "文章管理",
      "priority": "core",
      "description": "文章创建、编辑、发布、置顶、定时发布、回收站",
      "entities": ["Article", "Revision"]
    },
    {
      "name": "分类标签",
      "priority": "core",
      "description": "栏目管理、标签管理、SEO配置、URL别名",
      "entities": ["Category", "Tag"]
    },
    {
      "name": "媒体库",
      "priority": "important",
      "description": "图片/视频上传、分组管理、CDN加速、图床集成",
      "entities": ["Media"]
    },
    {
      "name": "内容审核",
      "priority": "important",
      "description": "待审列表、敏感词过滤、批量操作、审核记录",
      "entities": ["Article", "AuditLog"]
    },
    {
      "name": "评论管理",
      "priority": "important",
      "description": "评论审核、回复、敏感词过滤、垃圾评论识别",
      "entities": ["Comment"]
    },
    {
      "name": "页面管理",
      "priority": "optional",
      "description": "单页管理、自定义模板、友链管理",
      "entities": ["Page", "Link"]
    },
    {
      "name": "数据分析",
      "priority": "optional",
      "description": "访问统计、热门文章、趋势分析、数据导出",
      "entities": ["Article"]
    }
  ],
  "metadata": {
    "complexity": "medium",
    "estimatedTime": "2-3周",
    "techStack": ["React", "Node.js", "PostgreSQL", "OSS"],
    "tags": ["CMS", "内容管理", "文章", "博客", "媒体", "SEO"]
  }
}
