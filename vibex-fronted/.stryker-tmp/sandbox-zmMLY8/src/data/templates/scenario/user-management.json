{
  "id": "scenario-user-management",
  "name": "用户管理",
  "displayName": "通用用户管理系统",
  "category": "scenario",
  "icon": "👤",
  "description": "完整的用户管理功能模块，包含注册登录、权限管理、个人中心等",
  "content": "开发一个通用用户管理系统，包含以下核心功能：\n\n1. 用户注册登录：手机号/邮箱注册、密码登录、第三方登录\n2. 用户认证：实名认证、身份验证\n3. 个人中心：个人信息修改、头像上传、密码修改\n4. 地址管理：收货地址增删改查、默认地址设置\n5. 账户安全：登录记录、安全设置、异常告警\n6. 权限管理：角色配置、权限分配、菜单控制\n7. 用户管理：用户列表、用户详情、禁用/启用",
  "entities": [
    {
      "name": "User",
      "type": "aggregate",
      "attributes": ["id", "username", "email", "phone", "password", "avatar", "nickname", "gender", "birthday", "status", "lastLoginAt", "lastLoginIp", "createdAt", "updatedAt"],
      "description": "用户聚合根"
    },
    {
      "name": "UserProfile",
      "type": "entity",
      "attributes": ["userId", "realName", "idCard", "realNameVerified", "idCardVerified", "bio"],
      "description": "用户扩展信息"
    },
    {
      "name": "Address",
      "type": "entity",
      "attributes": ["id", "userId", "receiver", "phone", "province", "city", "district", "detail", "isDefault", "createdAt"],
      "description": "收货地址"
    },
    {
      "name": "Role",
      "type": "entity",
      "attributes": ["id", "name", "code", "description", "permissions", "createdAt"],
      "description": "角色"
    },
    {
      "name": "UserRole",
      "type": "valueObject",
      "attributes": ["userId", "roleId", "grantedBy", "grantedAt"],
      "description": "用户角色关联"
    },
    {
      "name": "LoginLog",
      "type": "entity",
      "attributes": ["id", "userId", "ip", "ua", "device", "location", "success", "failReason", "createdAt"],
      "description": "登录日志"
    },
    {
      "name": "SecuritySetting",
      "type": "valueObject",
      "attributes": ["userId", "loginAlert", "passwordChangedAt", "twoFactorEnabled"],
      "description": "安全设置"
    }
  ],
  "features": [
    {
      "name": "用户注册",
      "priority": "core",
      "description": "手机号/邮箱注册、密码设置、验证码",
      "entities": ["User"]
    },
    {
      "name": "用户登录",
      "priority": "core",
      "description": "密码登录、验证码登录、第三方登录",
      "entities": ["User", "LoginLog"]
    },
    {
      "name": "个人中心",
      "priority": "core",
      "description": "个人信息查看与修改、头像上传",
      "entities": ["User", "UserProfile"]
    },
    {
      "name": "收货地址",
      "priority": "important",
      "description": "地址增删改查、默认地址设置、地址验证",
      "entities": ["Address", "User"]
    },
    {
      "name": "账户安全",
      "priority": "important",
      "description": "修改密码、登录记录查看、安全告警设置",
      "entities": ["SecuritySetting", "LoginLog"]
    },
    {
      "name": "权限管理",
      "priority": "important",
      "description": "角色管理、权限配置、菜单控制",
      "entities": ["Role", "UserRole", "User"]
    },
    {
      "name": "用户列表",
      "priority": "important",
      "description": "用户搜索、详情查看、禁用启用",
      "entities": ["User"]
    }
  ],
  "metadata": {
    "complexity": "medium",
    "estimatedTime": "1-2周",
    "techStack": ["React", "Node.js", "PostgreSQL", "Redis"],
    "tags": ["用户管理", "注册登录", "RBAC", "权限", "个人中心"]
  }
}
