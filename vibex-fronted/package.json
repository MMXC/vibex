    "jsondiffpatch": "^0.7.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.13.0",
    "monaco-editor": "^0.53.0",
    "next": "16.2.0",
    "next-intl": "^4.8.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-resizable-panels": "^4.7.2",
