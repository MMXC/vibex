{
  "name": "vibex-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "jest",
    "test:json": "jest --json --outputFile=test-results.json",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:vitest": "echo 'Vitest placeholder script - project uses Jest'",
    "test:e2e": "playwright test",
    "test:e2e:ci": "npx playwright install --with-deps chromium && playwright test",
    "test:a11y": "playwright test --config playwright.a11y.config.ts",
    "vitest": "echo 'Use npm test for Jest tests'",
    "test:notify": "node scripts/test-notify.js",
    "pretest": "node scripts/pre-test-check.js",
    "pretest-check": "node scripts/pre-test-check.js",
    "coverage:check": "node scripts/check-coverage.js",
    "coverage:diff": "node scripts/coverage-diff.js",
    "coverage:history": "bash scripts/save-coverage-history.sh",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx,.mjs,.cjs --cache --cache-location node_modules/.cache/eslint/ --ignore-pattern '**/*.yml' --ignore-pattern '**/*.yaml' --ignore-pattern '.github/**' --ignore-pattern 'tests/**' && prettier --check .",
    "lint:css": "stylelint \"src/**/*.css\" \"src/**/**/*.css\"",
    "scan:css": "node scripts/scan-orphaned-css.js",
    "generate:types": "ts-node scripts/generate-types.ts",
    "prepare": "husky",
    "pre-commit-check": "tsc --noEmit && npx eslint ./src --max-warnings=0",
    "scan:vuln": "npm audit --audit-level=moderate",
    "report:vuln": "npm audit --json > vulnerability-report.json"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
