    "prettier": "^3.8.1",
    "storybook": "^8.6.17",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "ts-morph": "^27.0.2",
    "typescript": "^5",
    "vite": "^6.4.1",
    "wrangler": "^4.73.0"
