    "@tanstack/react-query-persist-client": "^5.90.24",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/dompurify": "^3.0.5",
    "@types/mermaid": "^9.1.0",
    "@xstate/react": "^6.1.0",
    "@xyflow/react": "^12.10.1",
    "axios": "^1.13.5",
    "axios-retry": "^4.5.0",
    "dompurify": "^3.3.2",
    "flatted": "^3.4.2",
