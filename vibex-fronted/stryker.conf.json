{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "jest",
  "coverageAnalysis": "all",
  "concurrency": 1,
  "jest": {
    "configFile": "jest.config.ts"
  },
  "mutate": [
    "src/lib/canvas/stores/contextStore.ts"
  ],
  "timeoutMS": 600000,
  "thresholds": {
    "break": 70,
    "high": 90,
    "low": 60
  },
  "reporters": [
    "progress",
    "html",
    "json"
  ],
  "tempDirName": ".stryker-tmp",
  "plugins": [
    "@stryker-mutator/jest-runner"
  ]
}
