{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "jest",
  "coverageAnalysis": "perTest",
  "concurrency": "100%",
  "jest": {
    "configFile": "jest.config.for-stryker.ts",
    "enableFindRelatedTests": false
  },
  "mutate": [
    "src/lib/canvas/stores/contextStore.ts:15:18"
  ],
  "timeoutMS": 300000,
  "disableTypeChecks": false,
  "thresholds": {
    "break": 70,
    "high": 90,
    "low": 60
  },
  "ignorePatterns": ["out/**", ".next/**", "node_modules/**", ".stryker-tmp/**"],
  "reporters": ["json"],
  "tempDirName": ".stryker-tmp",
  "plugins": ["@stryker-mutator/jest-runner"]
}
