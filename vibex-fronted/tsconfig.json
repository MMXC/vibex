{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strictNullChecks": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@vibex/types/*": [
        "../packages/types/src/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "noUncheckedIndexedAccess": true
  },
  "include": [
    "next-env.d.ts",
    "src/**/*",
    "lib/**/*",
    "app/**/*",
    "components/**/*",
    "hooks/**/*",
    "stores/**/*",
    "contexts/**/*",
    "config/**/*",
    "constants/**/*",
    "data/**/*",
    "middleware.ts",
    "**.d.ts",
    "*.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "jest.config.ts",
    "jest.config.for-stryker.ts",
    "jest.setup.ts",
    "jest.setup.js",
    "playwright.setup.ts",
    "src/services/__mocks__",
    "e2e"
  ]
}
